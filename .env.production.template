# Docker Production Environment Variables Template
# IMPORTANT: This file is for DOCKER PRODUCTION BUILDS ONLY
# DO NOT commit real secrets to git
# Use GitHub Secrets or .env file for actual deployment

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=8000

# Database (use production URL)
DATABASE_URL=postgresql://user:password@db-host:5432/stockpulse

# JWT Authentication - CHANGE IN PRODUCTION!
SECRET_KEY=your-production-secret-key-min-32-chars-change-this!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=<use-github-secret>
RAZORPAY_KEY_SECRET=<use-github-secret>

# Frontend URLs
REACT_APP_API_URL=https://api.stockpulse.com
VITE_API_URL=https://api.stockpulse.com

# Environment
NODE_ENV=production
PYTHON_ENV=production

# External APIs
NEWS_API_KEY=<use-github-secret>
STOCK_API_KEY=<use-github-secret>

# Redis Cache
REDIS_URL=redis://redis:6379

# Logging
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=https://stockpulse.com,https://www.stockpulse.com
